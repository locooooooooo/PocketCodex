# Copy this file to .env and fill values for your own deployment.
# Do not commit .env. It contains local or private deployment details.

# IP address or DNS name that RustDesk clients can reach.
RUSTDESK_HOST_IP=<HOST_IP_OR_DOMAIN>

# Relay host and port announced by hbbs.
RUSTDESK_RELAY_HOST=<HOST_IP_OR_DOMAIN>
RUSTDESK_RELAY_PORT=21117

